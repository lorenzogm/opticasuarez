# This project uses dotenvx for encrypted environment variables.
# The .env file is encrypted and safe to commit.
# See: https://dotenvx.com/docs/quickstart/encryption
#
# Setup:
#   1. Get the DOTENV_PRIVATE_KEY from a team member or 1Password
#   2. Create apps/web/.env.keys with:
#      DOTENV_PRIVATE_KEY="<your-key>"
#   3. Run: dotenvx run -- pnpm dev
#
# To add/update a secret:
#   dotenvx set KEY value -f apps/web/.env

# Base URL for the site (used in SEO meta, sitemaps, structured data)
VITE_BASE_URL=

# Resend API key for booking confirmation emails
RESEND_API_KEY=

# Sanity CMS
SANITY_PROJECT_ID=
SANITY_DATASET=
SANITY_API_TOKEN=

# Sanity webhook revalidation (HMAC-SHA256 shared secret)
SANITY_WEBHOOK_SECRET=

# Sanity Presentation tool preview secret
SANITY_PREVIEW_SECRET=

# GitHub PAT with actions:write scope (triggers deploy workflow)
GITHUB_DEPLOY_TOKEN=
